# =============================================================================
# DeathRoll — example environment file
# Copy this file to .env (or .env.luck / .env.dw on the VPS) and fill in.
# Real .env files are in .gitignore — NEVER commit them.
# =============================================================================

# ----- Shared (used by all bots) -----------------------------------------------
PG_ADMIN_USER=deathroll_admin
PG_ADMIN_PASSWORD=PLACEHOLDER_OPENSSL_RAND_BASE64_32
PG_LUCK_PASSWORD=PLACEHOLDER_OPENSSL_RAND_BASE64_32
PG_DW_PASSWORD=PLACEHOLDER_OPENSSL_RAND_BASE64_32
PG_READONLY_PASSWORD=PLACEHOLDER_OPENSSL_RAND_BASE64_32

# Used by deathroll_core/security/buttons.py to sign Discord button custom_ids
BUTTON_SIGNING_KEY=PLACEHOLDER_OPENSSL_RAND_HEX_32

# Used by core.audit_log hash chain
AUDIT_HASH_CHAIN_KEY=PLACEHOLDER_OPENSSL_RAND_HEX_32

# ----- Per-bot (one .env per bot in production) -------------------------------

# Luck bot
DISCORD_TOKEN_LUCK=PLACEHOLDER_FROM_DEVELOPER_PORTAL
GUILD_ID=PLACEHOLDER_DISCORD_SERVER_ID

# D/W bot
DISCORD_TOKEN_DW=PLACEHOLDER_FROM_DEVELOPER_PORTAL
# GUILD_ID is the same — single-guild deployment

# ----- Logging ----------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
